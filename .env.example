# Multi-RAG System Environment Variables
# Copy this file to .env and fill in your values

# Required: Google Gemini API Key
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenSearch Configuration (optional - defaults shown)
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200

# Ollama Configuration (optional - defaults shown)
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

# Application Settings (optional)
# APP_PORT=7860
# INDEX_NAME=pdf_content_index
# PDF_PATH=files/tani.pdf
# RESET_INDEX=false
# USE_GEMINI_CAPTIONS=true
# RERANK_RESULTS=true
